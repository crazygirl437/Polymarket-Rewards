# ============================================================================
# Polymarket 自动做市机器人配置（所有配置集中在此 .env）
# Polymarket market-making bot config (all settings live in this .env)
# 上半部分为常调参数，下半部分为基本固定参数
# Frequently-tuned params come first; rarely-changed params come later
# ============================================================================

# ██████████████████████████████████████████████████
# 【最小配置区 / Minimal required】必填项 / Required
# ██████████████████████████████████████████████████

# ---- 账户 / 钱包（必填，配置一次） / Account & wallet (required, set once) ----
# 私钥 / Private key
POLYMARKET_PRIVATE_KEY=
# 存款/代理钱包地址（与 polymarket.com/profile 中 proxyWallet 相同）
# Deposit/proxy wallet address (same as proxyWallet on polymarket.com/profile)
POLYMARKET_PROXY_ADDRESS=


# ██████████████████████████████████████████████████
# 【常用调参区 / Frequently tuned】按行情/策略调整 / Adjust per market & strategy
# ██████████████████████████████████████████████████

# ---- 做市策略 / Market-making strategy ----
# 最大选做市市场数量（基于收益比值排序）
# Max number of markets to make (ranked by reward ratio)
MAX_MARKETS=20
# 订单份额倍数（例如 1.0 表示使用市场最小奖励份额的 1 倍）
# Order size multiplier (e.g. 1.0 = 1x the market's min reward size)
ORDER_SIZE_MULTIPLIER=1.0
# 每市场最大敞口（USDC）
# Max exposure per market (USDC)
MAX_EXPOSURE_PER_MARKET_USDC=100
# 最小奖励比值阈值（奖励/流动性份额）
# Min reward ratio threshold (reward / liquidity size)
MIN_REWARD_RATIO=0
# 对冲卖出最小利润（基点，5 bps = 0.05%）
# Min profit for hedge sell (basis points, 5 bps = 0.05%)
MIN_PROFIT_MARGIN_BPS=5

# ---- 市场筛选 / Market filtering ----
# 价差过滤范围（绝对价差，留空表示不限制）
# Spread filter range (absolute spread; leave empty for no limit)
SPREAD_RANGE_MIN=0
SPREAD_RANGE_MAX=0.05
# 24小时交易量过滤范围（USDC，留空表示不限制）
# 24h volume filter range (USDC; leave empty for no limit)
VOLUME_24HR_RANGE_MIN=
VOLUME_24HR_RANGE_MAX=
# 最小奖励份额过滤范围（留空表示不限制）
# rewards_min_size filter range (leave empty for no limit)
REWARDS_MIN_SIZE_RANGE_MIN=20
REWARDS_MIN_SIZE_RANGE_MAX=20
# 市场结束时间限制（最小剩余天数，留空或 0 表示不限制）
# Market end-time limit (min days remaining; empty or 0 = no limit)
MIN_DAYS_UNTIL_END=

# ---- 主循环间隔 / Main loop intervals ----
# 市场扫描更新间隔（秒）
# Market scan/refresh interval (seconds)
UPDATE_INTERVAL_SECONDS=3600
# 订单状态检查间隔（秒）
# Order status check interval (seconds)
ORDER_CHECK_INTERVAL_SECONDS=2
# 订单簿监控更新间隔（秒，用于价格调整）
# Orderbook monitor interval (seconds, used for price adjustment)
ORDERBOOK_UPDATE_INTERVAL_SECONDS=0.5
# 价格偏离阈值（基点，超过此值才调整订单）
# Price deviation threshold (bps; only re-quote when exceeded)
PRICE_DEVIATION_THRESHOLD_BPS=0.0001

# ---- 风险管理 / Risk management ----
# 价格断层阈值（绝对差值）
# Price cliff threshold (absolute difference)
PRICE_CLIFF_THRESHOLD=0.05
# 最小保护份额倍数
# Min protection size multiplier
MIN_PROTECTION_SIZE_MULTIPLIER=1.0

# ---- 对冲卖出 / Hedge sell ----
# 使用买一价对冲时允许的最大价差
# Max bid gap allowed when hedging at best bid
HEDGE_SELL_MAX_BID_GAP=0.05


# ██████████████████████████████████████████████████████
# 【基本固定区 / Rarely changed】配置一次后通常无需改动 / Set once, rarely touch
# ██████████████████████████████████████████████████████

# ---- 交易配置 / Trading ----
# 签名类型（0=EOA, 1=POLY_PROXY 旧代理, 2=Gnosis Safe, 3=POLY_1271 存款钱包/V2）
# Signature type (0=EOA, 1=POLY_PROXY legacy, 2=Gnosis Safe, 3=POLY_1271 deposit wallet/V2)
SIGNATURE_TYPE=3
# 链ID（137=Polygon主网）
# Chain ID (137 = Polygon mainnet)
CHAIN_ID=137

# ---- 订单管理（重试/超时） / Order management (retry/timeout) ----
# 订单簿数据等待超时时间（秒）
# Orderbook data wait timeout (seconds)
ORDERBOOK_WAIT_TIMEOUT=3.0
# 订单重试次数
# Order retry count
ORDER_RETRY_COUNT=3
# 订单重试延迟（秒）
# Order retry delay (seconds)
ORDER_RETRY_DELAY=1.0

# ---- 订单簿数据服务 / Orderbook data service ----
# 是否启用订单簿数据服务
# Enable the orderbook data service
ORDERBOOK_SERVICE_ENABLED=true
# 市场扫描间隔（秒）
# Market scan interval (seconds)
ORDERBOOK_SERVICE_MARKET_SCAN_INTERVAL=300
# 订单簿更新间隔（秒）
# Orderbook update interval (seconds)
ORDERBOOK_SERVICE_ORDERBOOK_UPDATE_INTERVAL=30
# 批量获取订单簿的批次大小
# Batch size for fetching orderbooks
ORDERBOOK_SERVICE_BATCH_SIZE=200
# 完整市场详情 TTL（秒，默认 7 天）
# Full market detail TTL (seconds, default 7 days)
ORDERBOOK_SERVICE_MARKET_DETAIL_TTL=604800
# 批量获取市场详情的批次大小
# Batch size for fetching market details
ORDERBOOK_SERVICE_MARKET_DETAIL_BATCH_SIZE=20
# 每次扫描时最多补全的缺失市场详情数量
# Max missing market details to backfill per scan
ORDERBOOK_SERVICE_MARKET_DETAIL_FILL_PER_SCAN=20

# ---- 本地缓存存储（SQLite 后端，无需 Redis 服务） / Local cache (SQLite, no Redis) ----
# 订单簿数据过期时间（秒）
# Orderbook data expiry (seconds)
ORDERBOOK_TTL=300
# SQLite 数据库文件路径（留空则使用项目目录下 data/orderbook_cache.sqlite3）
# SQLite DB file path (empty = data/orderbook_cache.sqlite3 next to the program)
ORDERBOOK_DB_PATH=
